package-as: AzeriteUI5_JuNNeZ_Edition

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  # Development files
  - .github
  - .vscode
  - .research
  - .editorconfig
  - .gitignore
  - .gitattributes
  
  # Development documentation
  - AGENTS.md
  - FixLog.md
  - FixLog_Archive_*.md
  - Docs
  
  # Build scripts
  - build-release.ps1
  - "*.ps1"
  
  # IDE files
  - "*.code-workspace"
  - "*.sublime-*"
  
  # Temporary files
  - "*.bak"
  - "*.tmp"
  - "*.log"

externals:
  Libs/LibStub:
    url: https://repos.curseforge.com/wow/libstub/trunk
  Libs/CallbackHandler-1.0:
    url: https://repos.curseforge.com/wow/callbackhandler/trunk/CallbackHandler-1.0
  Libs/AceAddon-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceAddon-3.0
  Libs/AceDB-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceDB-3.0
  Libs/AceDBOptions-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceDBOptions-3.0
  Libs/AceEvent-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceEvent-3.0
  Libs/AceTimer-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceTimer-3.0
  Libs/AceConsole-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceConsole-3.0
  Libs/AceHook-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceHook-3.0
  Libs/AceLocale-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceLocale-3.0
  Libs/AceGUI-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceGUI-3.0
  Libs/AceConfig-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceConfig-3.0
  Libs/AceComm-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceComm-3.0
  Libs/AceSerializer-3.0:
    url: https://repos.curseforge.com/wow/ace3/trunk/AceSerializer-3.0
  Libs/LibSharedMedia-3.0:
    url: https://repos.curseforge.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  Libs/TaintLess:
    url: https://www.townlong-yak.com/addons.git/taintless
    commit: default
